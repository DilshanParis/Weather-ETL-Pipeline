# OpenWeatherMap
OPENWEATHER_API_KEY=replace_me
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5/weather
OPENWEATHER_UNITS=metric
DEFAULT_CITY=Colombo

# PostgreSQL (used by SQLAlchemy)
# Tip: if you run BOTH (1) Airflow in Docker and (2) Streamlit locally on Windows,
# keep Docker-friendly settings in `.env` and put local overrides in `.env.local`.
#
# - Docker containers reaching your host Postgres: POSTGRES_HOST=host.docker.internal
# - Local Windows apps reaching local Postgres:   POSTGRES_HOST=localhost
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=weather
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Optional: provide a full SQLAlchemy URL instead of the parts above
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/weather
